4. Código Backend: Rota de API (FASHN Try-On)
Claude, crie o arquivo app/api/tryon/route.ts. Esta rota será responsável por receber a imagem da persona e da roupa, e chamar o modelo FASHN via Fal.ai operando em resolução de 576x864
:
// app/api/tryon/route.ts
import { NextResponse } from 'next/server';
import * as fal from '@fal-ai/client';

export async function POST(request: Request) {
  try {
    const body = await request.json();
    const { person_image_url, garment_image_url } = body;

    if (!person_image_url || !garment_image_url) {
      return NextResponse.json({ error: 'As URLs da modelo e da roupa são obrigatórias.' }, { status: 400 });
    }

    // Chamada ao FASHN Virtual Try-On 1.5 no Fal.ai [3, 4]
    const result = await fal.subscribe('fal-ai/fashn/tryon/v1.5', {
      input: {
        model_image: person_image_url, // URL da Persona Base arquivada [7]
        garment_image: garment_image_url, // URL da Roupa (Flat-lay ou Manequim) [7]
        category: "tops", // Ajustável dinamicamente (tops, bottoms, one-pieces) [7]
      },
      logs: true,
      onQueueUpdate: (update) => {
        if (update.status === 'IN_PROGRESS') {
          console.log('Gerando imagem:', update.logs);
        }
      },
    });

    return NextResponse.json({ success: true, image_url: result.data.image.url });
  } catch (error: any) {
    console.error('Erro na geração do Fal.ai:', error);
    return NextResponse.json({ error: error.message || 'Erro interno' }, { status: 500 });
  }
}
